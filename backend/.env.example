# Copy this file to .env and fill in your values

# Option 1: Single DATABASE_URL (recommended for production/hosting like Render, Railway, Supabase)
# Format: postgresql://user:password@host:port/dbname
# DATABASE_URL=postgresql://postgres:Piyush@123@127.0.0.1:5432/hrms_lite

# Option 2: Individual vars (used when DATABASE_URL is not set)
DB_NAME=hrms_lite
DB_USER=postgres
DB_PASSWORD=Piyush@123
DB_HOST=127.0.0.1
DB_PORT=5432

# Django secret key (change in production!)
SECRET_KEY=django-insecure-hrms-lite-secret-key-change-in-production

# Set to False in production
DEBUG=True
